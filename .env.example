# Sift · self-host configuration
# Copy to .env then fill in your values.

# ─── Domain (Caddy auto-issues HTTPS) ──────────────────────
SIFT_DOMAIN=sift.example.com
SIFT_BASE_URL=https://sift.example.com

# ─── LLM provider (one of OpenAI-compatible APIs) ──────────
# DeepSeek (cheap, China-friendly): https://api.deepseek.com/v1/chat/completions
# SiliconFlow:                       https://api.siliconflow.cn/v1/chat/completions
# OpenAI:                            https://api.openai.com/v1/chat/completions
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-replace-me
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=8000

# ─── JWT secret (REQUIRED for production · 64 byte base64url) ─
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-64-byte-random-string

# ─── SaaS policy switches ──────────────────────────────────
INVITE_REQUIRED=false                # require invite code on register
EMAIL_VERIFY_REQUIRED=false          # block login until email verified
ADMIN_EMAILS=owner@example.com       # comma-separated admin allowlist

# ─── Email (SMTP · optional) ───────────────────────────────
# Used to send email verification links. If unset, verify URLs are
# printed to the container stdout (visible via `docker compose logs`).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Storage paths (inside the container, mapped to a volume) ─
SIFT_USERS_ROOT=/data/users
SIFT_DB=/data/sift.sqlite
